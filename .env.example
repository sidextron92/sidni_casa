# Origin ONLY — no /api, no trailing slash. The PocketBase SDK appends /api/... itself.
# Correct:   https://pb.srv884042.hstgr.cloud
# Wrong:     https://pb.srv884042.hstgr.cloud/        (trailing slash)
# Wrong:     https://pb.srv884042.hstgr.cloud/api/    (includes /api)
NEXT_PUBLIC_POCKETBASE_URL=https://pb.your-vps.example.com

# LLM provider for URL extraction. Values: "anthropic" (default) or "groq".
LLM_PROVIDER=anthropic

# Anthropic — used when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
# Optional model override (default: claude-haiku-4-5-20251001)
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Groq — used when LLM_PROVIDER=groq
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxx
# Optional model override (default: llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile
